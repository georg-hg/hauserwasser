{
  "name": "hauserwasser",
  "version": "1.0.0",
  "private": true,
  "description": "Fangbuch-App für Fischer an der Krems",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && node src/index.js",
    "db:migrate": "cd server && node src/db/migrate.js",
    "db:seed": "cd server && node src/db/seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
